# BuildFlow — Environment Configuration

# DATABASE: SQLite for Next.js web app (optional, only if using database features)
# DATABASE_URL="file:./dev.db"

# WEB APP: Port and API configuration
# Fixed port for stable Cloudflare tunnel and ProBot integration
# NEXT_PUBLIC_API_URL="http://localhost:3054"

# CHATGPT ACTIONS: Bearer token for /api/actions/* endpoints
# Generate with: openssl rand -hex 32
# Required at runtime for ChatGPT Custom Actions authentication
# BUILDFLOW_ACTION_TOKEN="<your-secret-token-here>"

# AGENT: Local agent endpoint for web app to forward requests to
# Default: http://127.0.0.1:3052 (agent running locally)
# Change this only if agent is on a different machine
# LOCAL_AGENT_URL="http://127.0.0.1:3052"

# RELAY: WebSocket bridge endpoint (for agent connection, not HTTP)
# Agent connects via WebSocket to relay for device registration and command routing
# BRIDGE_URL="ws://localhost:3053"

# BACKEND MODE: Which backend handles ChatGPT Actions requests (Phase 5+)
# Supported: direct-agent (default), relay-agent (Phase 5B+)
# direct-agent: web app -> local agent (3052) directly (default, most secure for local-only)
# relay-agent: web app -> relay (3053) -> agent (3052) via WebSocket (requires RELAY_PROXY_TOKEN)
# BUILDFLOW_BACKEND_MODE="direct-agent"

# RELAY PROXY TOKEN: Bearer token for relay-agent mode authentication (Phase 5C+)
# Only needed if BUILDFLOW_BACKEND_MODE=relay-agent
# Generate with: openssl rand -hex 32
# Must match RELAY_PROXY_TOKEN on the relay server
# Set on web app, relay will verify on /api/actions/proxy/* requests
# RELAY_PROXY_TOKEN="<your-relay-proxy-secret-token-here>"

# NODE ENVIRONMENT
# NODE_ENV="production"
